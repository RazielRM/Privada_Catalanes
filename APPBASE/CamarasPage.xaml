<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APPBASE.CamarasPage"
             Title="Cámaras en Vivo"
             BackgroundColor="#F5F5DC"
             NavigationPage.HasNavigationBar="False">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="SISTEMA DE VIGILANCIA" 
                   TextColor="#5D4037" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="2"/>

            <VerticalStackLayout Spacing="10">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="📹" FontSize="18"/>
                    <Label Text="Entrada Principal" 
                           TextColor="#5D4037" 
                           FontAttributes="Bold" 
                           FontSize="16"/>
                </HorizontalStackLayout>

                <Frame Padding="0" 
                       CornerRadius="15" 
                       BorderColor="#C19A6B" 
                       HasShadow="True" 
                       IsClippedToBounds="True"
                       BackgroundColor="Black">
                    <WebView Source="https://tu-url-de-camaras.com" 
                             HeightRequest="250" 
                             HorizontalOptions="FillAndExpand" />
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="🚘" FontSize="18"/>
                    <Label Text="Portón Vehicular" 
                           TextColor="#5D4037" 
                           FontAttributes="Bold" 
                           FontSize="16"/>
                </HorizontalStackLayout>

                <Frame Padding="0" 
                       CornerRadius="15" 
                       BorderColor="#C19A6B" 
                       HasShadow="True" 
                       IsClippedToBounds="True"
                       BackgroundColor="Black">

                    <WebView Source="https://tu-url-de-camaras-2.com" 
                             HeightRequest="250" 
                             HorizontalOptions="FillAndExpand" />
                </Frame>
            </VerticalStackLayout>

            <Label Text="* El tiempo de carga depende de la conexión de la privada." 
                   TextColor="#8D6E63" 
                   FontSize="11" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center" 
                   Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>