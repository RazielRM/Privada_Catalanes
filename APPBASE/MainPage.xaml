<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APPBASE.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5EFE6">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ══════════════════════════════════════════════ -->
        <!-- HEADER                                         -->
        <!-- ══════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="#6F4E37"
              HeightRequest="88"
              IsClippedToBounds="True"
              Padding="18,0,18,0">

            <Ellipse Fill="#7D5A44"
                     WidthRequest="200" HeightRequest="200"
                     HorizontalOptions="End" VerticalOptions="Center"
                     Margin="0,0,-60,0" Opacity="0.4"/>
            <Ellipse Fill="#5C3D28"
                     WidthRequest="120" HeightRequest="120"
                     HorizontalOptions="Start" VerticalOptions="Center"
                     Margin="-30,0,0,0" Opacity="0.3"/>

            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">

                <Border Grid.Column="0"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        WidthRequest="58" HeightRequest="58"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Image Source="cat.png"
                           HeightRequest="58" WidthRequest="58"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="1"
                                     VerticalOptions="Center"
                                     Margin="4,0,0,0">
                    <Label x:Name="lblBienvenida"
                           Text="Bienvenido"
                           TextColor="White"
                           FontSize="17"
                           FontAttributes="Bold"/>
                    <Label x:Name="lblEstado"
                           Text="● Conectado"
                           TextColor="#D4B59E"
                           FontSize="11"/>
                </VerticalStackLayout>

                <Frame Grid.Column="2"
                       BackgroundColor="Transparent"
                       BorderColor="#D4B59E"
                       CornerRadius="20"
                       Padding="12,6"
                       VerticalOptions="Center">
                    <Label Text="Salir"
                           TextColor="#D4B59E"
                           FontSize="13"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarSesionClicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>

            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════ -->
        <!-- CENTRO — FlexLayout responsive                 -->
        <!-- ══════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <FlexLayout Wrap="Wrap"
                        JustifyContent="Center"
                        AlignItems="Center"
                        AlignContent="Center"
                        Padding="14,20,14,14">

                <!-- Puerta Peatonal -->
                <Frame x:Name="btnPeatonal"
                       BackgroundColor="#FFFFFF"
                       CornerRadius="24" HasShadow="True"
                       BorderColor="#EDD9C8" Padding="0"
                       HeightRequest="140" WidthRequest="155"
                       Margin="7"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#FDF0E6"
                                WidthRequest="56" HeightRequest="56"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="🚪" FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Puerta Peatonal"
                               TextColor="#3E2008" FontAttributes="Bold"
                               FontSize="13" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAbrirPuertaClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Portón Vehicular -->
                <Frame x:Name="btnPorton"
                       BackgroundColor="#FFFFFF"
                       CornerRadius="24" HasShadow="True"
                       BorderColor="#EDD9C8" Padding="0"
                       HeightRequest="140" WidthRequest="155"
                       Margin="7"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#FDF0E6"
                                WidthRequest="56" HeightRequest="56"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="🚘" FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Portón Vehicular"
                               TextColor="#3E2008" FontAttributes="Bold"
                               FontSize="13" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAbrirPortonClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Cámaras -->
                <Frame x:Name="btnCamaras"
                       BackgroundColor="#FFFFFF"
                       CornerRadius="24" HasShadow="True"
                       BorderColor="#EDD9C8" Padding="0"
                       HeightRequest="140" WidthRequest="155"
                       Margin="7"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#FDF0E6"
                                WidthRequest="56" HeightRequest="56"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="📹" FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Cámaras En Vivo"
                               TextColor="#3E2008" FontAttributes="Bold"
                               FontSize="13" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVerCamarasClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Historial -->
                <Frame x:Name="btnVerHistorial"
                       BackgroundColor="#FFFFFF"
                       CornerRadius="24" HasShadow="True"
                       BorderColor="#EDD9C8" Padding="0"
                       HeightRequest="140" WidthRequest="155"
                       Margin="7"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#FDF0E6"
                                WidthRequest="56" HeightRequest="56"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="📜" FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Ver Historial"
                               TextColor="#3E2008" FontAttributes="Bold"
                               FontSize="13" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVerHistorialClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Alarma — ancho completo -->
                <Frame x:Name="btnAlarma"
                       BackgroundColor="#C0392B"
                       CornerRadius="20" HasShadow="True"
                       BorderColor="#922B21" Padding="0"
                       HeightRequest="62" WidthRequest="330"
                       Margin="7"
                       IsVisible="False">
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="20,0" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="📣"
                               FontSize="22" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center" Spacing="1">
                            <Label Text="ALARMA VECINAL"
                                   TextColor="White" FontAttributes="Bold" FontSize="14"/>
                            <Label Text="Toca para activar"
                                   TextColor="#F1948A" FontSize="10"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAlarmaVecinalClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Adeudo -->
                <Frame x:Name="frameAdeudo"
                       BackgroundColor="#FFF5F5"
                       CornerRadius="14" BorderColor="#E57373"
                       Padding="16,12" WidthRequest="330"
                       Margin="7"
                       IsVisible="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="⚠️"
                               FontSize="20" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2" VerticalOptions="Center">
                            <Label Text="Adeudo pendiente"
                                   TextColor="#C0392B" FontAttributes="Bold" FontSize="13"/>
                            <Label Text="Contacte a administración para regularizar."
                                   TextColor="#E57373" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

            </FlexLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════ -->
        <!-- FOOTER — Panel admin                           -->
        <!-- ══════════════════════════════════════════════ -->
        <VerticalStackLayout x:Name="AdminPanel"
                             Grid.Row="2"
                             Spacing="10"
                             Padding="18,12,18,24"
                             IsVisible="False">

            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <BoxView Grid.Column="0" HeightRequest="1" Color="#D4B59E"
                         VerticalOptions="Center" Opacity="0.6"/>
                <Label Grid.Column="1" Text="ADMINISTRACIÓN"
                       TextColor="#A07850" FontSize="10" FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <BoxView Grid.Column="2" HeightRequest="1" Color="#D4B59E"
                         VerticalOptions="Center" Opacity="0.6"/>
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Frame x:Name="btnAdminCasas"
                       Grid.Column="0"
                       BackgroundColor="#FFFFFF"
                       BorderColor="#EDD9C8"
                       CornerRadius="16" HasShadow="True"
                       Padding="0" HeightRequest="72"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="🏠" FontSize="22" HorizontalOptions="Center"/>
                        <Label Text="Casas" TextColor="#6F4E37"
                               FontAttributes="Bold" FontSize="12"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnIrAGestionCasasClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame x:Name="btnAdminLista"
                       Grid.Column="1"
                       BackgroundColor="#FFFFFF"
                       BorderColor="#EDD9C8"
                       CornerRadius="16" HasShadow="True"
                       Padding="0" HeightRequest="72"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="👥" FontSize="22" HorizontalOptions="Center"/>
                        <Label Text="Vecinos" TextColor="#6F4E37"
                               FontAttributes="Bold" FontSize="12"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVerListaUsuariosClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame x:Name="btnAdminRegistrar"
                       Grid.Column="2"
                       BackgroundColor="#6F4E37"
                       BorderColor="#6F4E37"
                       CornerRadius="16" HasShadow="True"
                       Padding="0" HeightRequest="72"
                       IsVisible="False">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="➕" FontSize="22" HorizontalOptions="Center"/>
                        <Label Text="Nuevo" TextColor="White"
                               FontAttributes="Bold" FontSize="12"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnIrARegistroClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

            </Grid>

        </VerticalStackLayout>

    </Grid>
</ContentPage>