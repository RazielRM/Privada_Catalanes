<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APPBASE.ListaUsuariosPage"
             Title="Lista de Vecinos"
             BackgroundColor="#F5F5DC"
             NavigationPage.HasNavigationBar="False">

    <VerticalStackLayout Padding="20" Spacing="10">

        <!-- TITULO -->
        <Label Text="DIRECTORIO DE VECINOS"
               TextColor="#5D4037"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <!-- BUSCADOR -->
        <SearchBar x:Name="searchUsuarios"
                   Placeholder="Buscar vecino..."
                   TextChanged="OnBuscarUsuario"
                   BackgroundColor="White"
                   TextColor="#5D4037"/>

        <!-- LISTA -->
        <CollectionView x:Name="lstUsuarios"
                        SelectionMode="Single"
                        SelectionChanged="OnUsuarioSeleccionado">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Grid Padding="15"
                          Margin="0,6"
                          BackgroundColor="White">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icono -->
                        <Label Text="👤"
                               FontSize="22"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                        
                        
                        
                        

                        <!-- Nombre -->
                        <Label Grid.Column="1"
                               Text="{Binding Nombre}"
                               FontSize="18"
                               TextColor="#5D4037"
                               VerticalOptions="Center"/>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>